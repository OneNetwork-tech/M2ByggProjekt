# ── Database & server-only data (never commit live data) ──
data/*.sqlite
data/*.sqlite-wal
data/*.sqlite-shm
data/*.db
data/backups/*
data/portal-uploads/*
!data/backups/.gitkeep
!data/portal-uploads/.gitkeep

# ── Secrets / local config ──
.env
config.local.php
config.local.php.*

# ── OS / editor junk ──
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/
*.swp

# ── Uploads ──
# Static site-asset images (hero photos, etc.) committed at the top level of uploads/
# ARE tracked — pages reference them directly. Only CRM-admin-uploaded content
# (portfolio/service images added live via crm/portfolio.php, crm/tjanster.php)
# is excluded, since that's live server data, not part of the codebase.
uploads/portfolio/*
uploads/services/*
!uploads/portfolio/.gitkeep
!uploads/services/.gitkeep
